# =============================================
# CONFIGURACIÓN DEL BOT "PARA ESO TRABAJO"
# =============================================

# Credenciales de la Aplicación de Meta (Meta Developer Portal)
META_APP_ID=tu_meta_app_id
META_APP_SECRET=tu_meta_app_secret

# Token corto (temporal — se usa únicamente para generar el token de larga duración)
SHORT_LIVED_TOKEN=tu_token_corto_temporal

# Token de larga duración de la página (se genera corriendo el script get_long_token.js)
PAGE_ACCESS_TOKEN=tu_page_access_token_larga_duracion

# ID de la página de Facebook "Para eso trabajo"
PAGE_ID=tu_facebook_page_id

# Tag de afiliado de Mercado Libre (si aplica)
MELI_AFFILIATE_TAG=tu_tag_de_afiliado

# Llave de API de Google Gemini (requerida para master_affiliate.js)
GEMINI_API_KEY=tu_gemini_api_key
